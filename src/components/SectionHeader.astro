---
const { eyebrow, title, description, href, linkLabel } = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
};
---

<div class="section-header">
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>
  {href && linkLabel && <a class="text-link" href={href}>{linkLabel}</a>}
</div>
